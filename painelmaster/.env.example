# ==============================================================================
# PainelMaster — variáveis de ambiente de PRODUÇÃO
# Copie para `.env` e ajuste. Nunca commite o .env real.
# Gere secrets fortes: openssl rand -hex 32
# ==============================================================================

# Nome do projeto no Docker Compose (evita conflito de containers/redes/volumes com outros projetos)
COMPOSE_PROJECT_NAME=painelmaster-v2

# ----- Banco de dados (PostgreSQL via Docker Compose) -----
POSTGRES_DB=painelmaster
POSTGRES_USER=painel
POSTGRES_PASSWORD=TROQUE_POSTGRES_PASS
DATABASE_URL=postgresql://painel:TROQUE_POSTGRES_PASS@postgres:5432/painelmaster?schema=public

# ----- Segurança -----
JWT_SECRET=TROQUE_32_BYTES_HEX
JWT_REFRESH_SECRET=TROQUE_32_BYTES_HEX
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=TROQUE_32_CHARS_EXATOS_0123456789

# ----- URLs públicas -----
FRONTEND_URL=https://painel.seudominio.com
API_URL=https://painel.seudominio.com/api
ALLOWED_ORIGINS=https://painel.seudominio.com,https://*.seudominio.com

# ----- Frontend (build time) -----
VITE_API_URL=/api
VITE_APP_NAME=PainelMaster
VITE_LANDING_HOSTNAME=

# ----- Seed SUPER_ADMIN -----
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@seudominio.com
SEED_ADMIN_PASSWORD=TROQUE_NO_PRIMEIRO_LOGIN
ENABLE_HSTS=true
COOKIE_SECURE=
EDGE_FORCE_HTTP=false

# ----- Timezone -----
TZ=America/Sao_Paulo

# ----- TMDB (opcional; também via UI) -----
TMDB_API_KEY=
TMDB_API_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/original

# ----- Integrações opcionais (também via UI por usuário) -----
BOTBOT_APP_KEY=
BOTBOT_AUTH_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ----- XUI fallback (preferir cadastrar pela UI) -----
XUI_API_BASE_URL=
XUI_API_ACCESS_CODE=
XUI_API_KEY=

# ----- Feature flags -----
CONTENT_SYNC_ENABLED=true
NODE_ENV=production
PORT=3001
